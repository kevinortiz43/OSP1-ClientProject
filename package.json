{
  "name": "src",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "restart": "docker compose down && docker compose build --no-cache",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "csv-manual": "bun ./src/server/sql_db/convertData_manual.ts",
    "csv-module": "bun ./src/server/sql_db/convertData_module.ts",
    "csv-agno": "bun ./src/server/sql_db/convertData_agnostic.ts",
    "seed-supabase": "bun ./src/server/sql_db/seed.ts supabase",
    "seed-local": "bun ./src/server/sql_db/seed_local.ts",
    "seed-agno": "bun ./src/server/sql_db/seed_agnostic.ts",
    "types-supabase": "bun ./src/server/sql_db/generateSchema.ts",
    "types-local": "bun ./src/server/sql_db/generateSchema_local.ts",
    "types-agno": "bun ./src/server/sql_db/generateSchema_agnostic.ts",
    "db-setup-agno": "bun run csv-agno && bun run seed-agno && bun run types-agno",
    "db-setup-localLinux": "bun run csv-module && bun run seed-local && bun run types-local",
    "dev": "concurrently \"bun run start\" \"bun run server\"",
    "start": "bun vite",
    "server": "bun run --watch src/server/server.ts ",
    "tear": "docker compose down && docker system prune --all --volumes --force",
    "watch": "docker compose up --watch",
    "devo": "bun i && bun run setup && bun run watch",
    "setup": "docker compose up -d && bun run csv-agno && bun run seed-agno && bun run types-agno"
  },
  "dependencies": {
   "@elysiajs/cors": "^1.4.1",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-regular-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.1",
    "@huggingface/inference": "^4.13.12",
    "@json2csv/plainjs": "^7.0.6",
    "@types/cors": "^2.8.19",
    "@types/pg": "^8.16.0",
    "@types/pg-copy-streams": "^1.2.5",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "elysia": "^1.4.25",
    "express": "^5.2.1",
    "node-cache": "^5.1.2",
    "pg": "^8.18.0",
    "pg-copy-streams": "^7.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-select": "^5.10.2"






    
  },
  "devDependencies": {
      "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "concurrently": "^9.2.1",
    "csv-parse": "^6.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "react-icons": "^5.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
